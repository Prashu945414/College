import tkinter as tk
import random
import string

root = tk.Tk()
root.title("Random Password Generator")

tk.Label(root, text="Password Length").pack()

spinbox = tk.Spinbox(root, from_=4, to=100)
spinbox.pack()

num_var = tk.IntVar()
sym_var = tk.IntVar()

tk.Checkbutton(root, text="Include Numbers", variable=num_var).pack()
tk.Checkbutton(root, text="Include Symbols", variable=sym_var).pack()

def generate_password():

 password =""

 pool = string.ascii_letters

 length = int(spinbox.get())
 remaining_length = length - len(password)

 if num_var.get() == 1:
    pool += string.digits

 if sym_var.get() == 1:
    pool += string.punctuation

 for _ in range(remaining_length):
    password += random.choice(pool)

 password = list(password)
 password = "".join(password)
 
 result.delete(0, tk.END)
 result.insert(0, password)

result = tk.Entry(root)
result.pack()

button = tk.Button(root, text="Generate Password", width=28, command=generate_password)
button.pack()

root.mainloop()
